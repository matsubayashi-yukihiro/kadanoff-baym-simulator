{
  "name": "tdkb-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "generate:api:schema": "node ./scripts/generate-openapi.mjs",
    "generate:api:types": "openapi-typescript ./openapi.json --output ./src/api/generated.ts",
    "generate:api": "npm run generate:api:schema && npm run generate:api:types"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "plotly.js-dist-min": "^3.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^7.6.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.0",
    "@types/plotly.js": "^3.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.0",
    "openapi-typescript": "^7.6.1",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
