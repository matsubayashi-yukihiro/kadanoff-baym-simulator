{
  "name": "tdkb-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "generate:api:schema": "node ./scripts/generate-openapi.mjs",
    "generate:api:types": "openapi-typescript ./openapi.json --output ./src/api/generated.ts",
    "generate:api": "npm run generate:api:schema && npm run generate:api:types"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.4.8",
    "@testing-library/react": "14.3.1",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "18.19.31",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "@types/scheduler": "0.16.8",
    "@vitejs/plugin-react": "4.2.1",
    "jsdom": "21.1.2",
    "openapi-typescript": "6.7.5",
    "typescript": "5.4.5",
    "vite": "4.5.5",
    "vitest": "0.34.6"
  }
}
